---
import type { ImageMetadata } from "astro";
import type { CoverImage } from "../utils/cover-image";
import { normalizeCover } from "../utils/cover-image";
import { pageTitle, routes, siteConfig, withBasePath } from "../config/site";
import AdvertisementBanner from "../components/AdvertisementBanner.astro";
import BaseLayout from "./BaseLayout.astro";
import CategoryBadge from "../components/CategoryBadge.astro";
import PageContainer from "../components/PageContainer.astro";
import SharePost from "../components/SharePost.astro";
import TagBadge from "../components/TagBadge.astro";
import ThemedImage from "../components/ThemedImage.astro";
import { Icon } from "astro-icon/components";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    updated?: Date;
    category: string;
    tags: string[];
    cover?: ImageMetadata | string;
    cover_alt?: string;
  };
  readingTime?: number;
}

const { frontmatter, readingTime } = Astro.props;
const cover = normalizeCover(frontmatter.cover);

const slug = Astro.params.slug;

const socialIconMap: Record<string, string> = {
  x: "tabler:brand-x",
  github: "tabler:brand-github",
  linkedin: "tabler:brand-linkedin",
  telegram: "tabler:brand-telegram",
  email: "tabler:mail",
};

const formattedDate = frontmatter.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdated = frontmatter.updated?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const canonicalUrl = Astro.url.href;
const coverPath = cover
  ? cover.src.startsWith("/") ? withBasePath(siteConfig.basePath, cover.src) : cover.src
  : undefined;
const imageUrl = new URL(coverPath ?? routes.ogDefault, Astro.site ?? Astro.url).href;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: frontmatter.date.toISOString(),
  ...(frontmatter.updated ? { dateModified: frontmatter.updated.toISOString() } : {}),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  image: imageUrl,
  inLanguage: "en-US",
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    ...(siteConfig.author.url ? { url: siteConfig.author.url } : {}),
  },
  publisher: {
    "@type": "Organization",
    name: siteConfig.name,
    url: siteConfig.publicSiteUrl,
  },
  isPartOf: {
    "@type": "Blog",
    name: siteConfig.name,
    url: siteConfig.publicSiteUrl,
  },
};
---

<BaseLayout
  title={pageTitle(frontmatter.title)}
  description={frontmatter.description}
  image={cover}
  ogType="article"
  publishedTime={frontmatter.date.toISOString()}
  modifiedTime={frontmatter.updated?.toISOString()}
  structuredData={structuredData}
>
  <PageContainer class={cover ? "" : "pb-5 sm:pb-6"}>
    <AdvertisementBanner
      href={siteConfig.advertisement?.href || ""}
      imageUrl={siteConfig.advertisement?.imageUrl}
      alt={siteConfig.advertisement?.alt}
      title={siteConfig.advertisement?.title}
      description={siteConfig.advertisement?.description}
    />
    <div class="max-w-3xl">
      <header class="mb-8">
        <CategoryBadge category={frontmatter.category} class="mb-4" />
        <h1 class="mb-4 text-4xl font-semibold tracking-tight sm:text-5xl">{frontmatter.title}</h1>
        <p class="text-base-content/68 mb-5 max-w-2xl text-lg leading-8">
          {frontmatter.description}
        </p>
        <div class="text-base-content/46 flex flex-wrap items-center gap-3 font-mono text-xs tracking-[0.08em] uppercase">
          <time datetime={frontmatter.date.toISOString()}>{formattedDate}</time>
          {readingTime && <span>·</span>}
          {readingTime && <span>{readingTime} min read</span>}
          {formattedUpdated && <span>· Updated {formattedUpdated}</span>}
        </div>
        {
          frontmatter.tags.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {frontmatter.tags.map((tag) => (
                <TagBadge tag={tag} />
              ))}
            </div>
          )
        }
      </header>
    </div>
  </PageContainer>

  {
    cover && (
      <div class="bg-base-200/55 overflow-hidden lg:mx-auto lg:max-w-5xl">
        <ThemedImage
          image={cover}
          alt={frontmatter.cover_alt ?? frontmatter.title}
          loading="eager"
          class="h-auto w-full object-cover"
        />
      </div>
    )
  }

  <PageContainer class={cover ? "" : "pt-5 sm:pt-6"}>
    <div class="max-w-3xl">
      <article class="prose max-w-none text-[1.03rem] leading-8">
        <slot />
      </article>
      <hr class="my-10 border-base-content/10" />
      <SharePost title={frontmatter.title} url={canonicalUrl} />
      <hr class="my-10 border-base-content/10" />

      <div class="flex flex-wrap items-center gap-5">
        <div class="flex items-center gap-3.5">
          <img
            src="/author-light.svg"
            alt=""
            class="h-12 w-12 shrink-0 object-cover theme-invert-dark ring-1 ring-base-content/10"
          />
          <div class="min-w-0">
            <p class="page-kicker">Written by</p>
            {siteConfig.author.url ? (
              <a href={siteConfig.author.url} class="text-sm font-semibold text-base-content hover:text-primary transition-colors duration-200">{siteConfig.author.name}</a>
            ) : (
              <span class="text-sm font-semibold text-base-content">{siteConfig.author.name}</span>
            )}
          </div>
        </div>

        {siteConfig.author.socials && siteConfig.author.socials.length > 0 && (
          <>
            <div class="hidden h-4 w-px bg-base-content/10 sm:block" />
            <div class="flex items-center gap-3">
              {siteConfig.author.socials.map((social) => (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-base-content/40 hover:text-primary transition-colors duration-200"
                  aria-label={social.platform}
                >
                  <Icon name={socialIconMap[social.platform.toLowerCase()] ?? "tabler:link"} class="h-[1.1rem] w-[1.1rem]" />
                </a>
              ))}
            </div>
          </>
        )}
      </div>

      {slug && (
        <div
          data-analytics-post
          data-slug={slug}
          data-title={frontmatter.title}
          aria-hidden="true"
          class="hidden"
        />
      )}

      {import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID && (
        <script>
          import { trackPostView } from "../firebase/events";

          const el = document.querySelector("[data-analytics-post]");
          if (el instanceof HTMLElement) {
            const slug = el.dataset.slug;
            const title = el.dataset.title;
            if (slug && title) trackPostView(slug, title);
          }
        </script>
      )}

    </div>
  </PageContainer>
</BaseLayout>
