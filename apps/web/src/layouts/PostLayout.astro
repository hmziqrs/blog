---
import type { ImageMetadata } from "astro";
import { pageTitle, routes, siteConfig, withBasePath } from "../config/site";
import BaseLayout from "./BaseLayout.astro";
import CategoryBadge from "../components/CategoryBadge.astro";
import PageContainer from "../components/PageContainer.astro";
import TagBadge from "../components/TagBadge.astro";
import ThemedImage from "../components/ThemedImage.astro";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    updated?: Date;
    category: string;
    tags: string[];
    cover?: ImageMetadata;
  };
  readingTime?: number;
}

const { frontmatter, readingTime } = Astro.props;

const formattedDate = frontmatter.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdated = frontmatter.updated?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const canonicalUrl = Astro.url.href;
const coverPath = frontmatter.cover
  ? withBasePath(siteConfig.basePath, frontmatter.cover.src)
  : undefined;
const imageUrl = new URL(coverPath ?? routes.ogDefault, Astro.site ?? Astro.url).href;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: frontmatter.date.toISOString(),
  ...(frontmatter.updated ? { dateModified: frontmatter.updated.toISOString() } : {}),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  image: imageUrl,
  inLanguage: "en-US",
  publisher: {
    "@type": "Organization",
    name: siteConfig.name,
    url: siteConfig.publicSiteUrl,
  },
  isPartOf: {
    "@type": "Blog",
    name: siteConfig.name,
    url: siteConfig.publicSiteUrl,
  },
};
---

<BaseLayout
  title={pageTitle(frontmatter.title)}
  description={frontmatter.description}
  image={frontmatter.cover}
  structuredData={structuredData}
>
  <PageContainer>
    <div class="max-w-3xl">
      <header class="mb-8">
        <CategoryBadge category={frontmatter.category} class="mb-4" />
        <h1 class="mb-4 text-4xl font-semibold tracking-tight sm:text-5xl">{frontmatter.title}</h1>
        <p class="text-base-content/68 mb-5 max-w-2xl text-lg leading-8">
          {frontmatter.description}
        </p>
        <div class="text-base-content/46 flex flex-wrap items-center gap-3 font-mono text-xs tracking-[0.08em] uppercase">
          <time datetime={frontmatter.date.toISOString()}>{formattedDate}</time>
          {readingTime && <span>·</span>}
          {readingTime && <span>{readingTime} min read</span>}
          {formattedUpdated && <span>· Updated {formattedUpdated}</span>}
        </div>
        {
          frontmatter.cover && (
            <div class="border-base-300 bg-base-200/55 mt-6 overflow-hidden rounded-[1.75rem] border">
              <ThemedImage
                image={frontmatter.cover}
                alt={frontmatter.title}
                loading="eager"
                class="h-auto w-full object-cover"
              />
            </div>
          )
        }
        {
          frontmatter.tags.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {frontmatter.tags.map((tag) => (
                <TagBadge tag={tag} />
              ))}
            </div>
          )
        }
      </header>
      <article class="prose max-w-none text-[1.03rem] leading-8">
        <slot />
      </article>
    </div>
  </PageContainer>
</BaseLayout>
