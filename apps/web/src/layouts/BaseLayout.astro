---
import type { CoverImage } from "../utils/cover-image";
import { extractTwitterHandle } from "../utils/meta";
import { ClientRouter } from "astro:transitions";
import { routes, siteConfig, withBasePath } from "../config/site";
import ConsentBanner from "../components/ConsentBanner.astro";
import ColorTweaks from "../components/ColorTweaks.astro";
import LightModeWarningModal from "../components/LightModeWarningModal.astro";
import NewsletterModal from "../components/NewsletterModal.astro";
import StructuredData from "../components/StructuredData.astro";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
  description?: string;
  image?: CoverImage;
  noindex?: boolean;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = siteConfig.name,
  description = siteConfig.blog.homeDescription,
  image,
  noindex = false,
  ogType = "website",
  publishedTime,
  modifiedTime,
  structuredData,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogPath = image
  ? image.src.startsWith("/") ? withBasePath(siteConfig.basePath, image.src) : image.src
  : undefined;
const ogImage = new URL(ogPath ?? routes.ogDefault, Astro.site);
const twitterHandle = extractTwitterHandle(siteConfig.author.socials);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/author-light.svg" data-theme-favicon />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {twitterHandle && <meta name="twitter:site" content={`@${twitterHandle}`} />}
    {twitterHandle && <meta name="twitter:creator" content={`@${twitterHandle}`} />}

    <meta property="og:locale" content="en_US" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="theme-color" content="#0a0a0f" />

    <link rel="alternate" type="application/rss+xml" title={siteConfig.name} href={routes.rss} />
    <StructuredData data={structuredData} />

    <script is:inline>
      const themeKey = "theme";
      const lightWarningKey = "theme-light-warning-dismissed";
      const defaultTheme = "dark";

      function getTheme() {
        try {
          const savedTheme = window.localStorage.getItem(themeKey);
          return savedTheme === "light" || savedTheme === "dark" ? savedTheme : defaultTheme;
        } catch {
          return defaultTheme;
        }
      }

      function applyTheme(theme) {
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme === "dark" ? "dark" : "light";

        const favicon = document.querySelector("link[rel='icon'][data-theme-favicon]");
        if (favicon) {
          favicon.href = theme === "dark" ? "/author-dark.svg" : "/author-light.svg";
        }

        document.querySelectorAll("[data-theme-toggle]").forEach((toggle) => {
          const label = theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
          toggle.setAttribute("aria-label", label);
          toggle.setAttribute("title", label);
          toggle.setAttribute("aria-pressed", String(theme === "light"));
        });
      }

      function setTheme(theme) {
        applyTheme(theme);
        try {
          window.localStorage.setItem(themeKey, theme);
        } catch {}
      }

      function syncThemeToggle() {
        applyTheme(getTheme());
      }

      function isLightWarningDismissed() {
        try {
          return window.localStorage.getItem(lightWarningKey) === "true";
        } catch {
          return false;
        }
      }

      function showLightModeWarning() {
        document.dispatchEvent(new CustomEvent("light-mode-warning:show"));
      }

      applyTheme(getTheme());

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const toggle = target.closest("[data-theme-toggle]");
        if (toggle instanceof HTMLButtonElement) {
          const currentTheme = document.documentElement.dataset.theme;
          if (currentTheme === "dark") {
            if (isLightWarningDismissed()) {
              setTheme("light");
            } else {
              showLightModeWarning();
            }
          } else {
            setTheme("dark");
          }
          return;
        }

        const postCard = target.closest("[data-post-card]");
        if (!(postCard instanceof HTMLElement)) return;
        if (target.closest("a, button, input, textarea, select, summary")) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

        const href = postCard.dataset.postUrl;
        if (!href) return;

        window.location.assign(href);
      });

      document.addEventListener("astro:after-swap", syncThemeToggle);
      document.addEventListener("astro:page-load", syncThemeToggle);
      document.addEventListener("DOMContentLoaded", syncThemeToggle);
    </script>

    <title>{title}</title>
    <slot name="head" />
    <ClientRouter />

    {import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID && (
      <script>
        import "../firebase/client";
      </script>
    )}
  </head>
  <body class="bg-base-100 text-base-content antialiased">
    <Header />
    <main class="pb-16">
      <slot />
    </main>

    <LightModeWarningModal />

    <Footer />

    <NewsletterModal siteKey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || ""} />
    <ConsentBanner />
    <ColorTweaks />
  </body>
</html>
