---
import type { ImageMetadata } from "astro";
import { ClientRouter } from "astro:transitions";
import { routes, siteConfig, withBasePath } from "../config/site";
import StructuredData from "../components/StructuredData.astro";
import NewsletterModal from "../components/NewsletterModal.astro";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string | ImageMetadata;
  noindex?: boolean;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = siteConfig.name,
  description = siteConfig.blog.homeDescription,
  image,
  noindex = false,
  ogType = "website",
  publishedTime,
  modifiedTime,
  structuredData,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const imagePath = typeof image === "string" ? image : image?.src;
const ogPath =
  imagePath?.startsWith("/") ? withBasePath(siteConfig.basePath, imagePath) : imagePath;
const ogImage = new URL(ogPath ?? routes.ogDefault, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={routes.favicon} />
    <link rel="apple-touch-icon" href={routes.favicon} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title={siteConfig.name} href={routes.rss} />
    <StructuredData data={structuredData} />

    <script is:inline>
      const themeKey = "theme";
      const lightWarningKey = "theme-light-warning-dismissed";
      const defaultTheme = "dark";

      function getTheme() {
        try {
          const savedTheme = window.localStorage.getItem(themeKey);
          return savedTheme === "light" || savedTheme === "dark" ? savedTheme : defaultTheme;
        } catch {
          return defaultTheme;
        }
      }

      function applyTheme(theme) {
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme === "dark" ? "dark" : "light";

        document.querySelectorAll("[data-theme-toggle]").forEach((toggle) => {
          const label = theme === "dark" ? "Switch to light mode" : "Switch to dark mode";
          toggle.setAttribute("aria-label", label);
          toggle.setAttribute("title", label);
          toggle.setAttribute("aria-pressed", String(theme === "light"));
        });
      }

      function setTheme(theme) {
        applyTheme(theme);
        try {
          window.localStorage.setItem(themeKey, theme);
        } catch {}
      }

      function syncThemeToggle() {
        applyTheme(getTheme());
      }

      function isLightWarningDismissed() {
        try {
          return window.localStorage.getItem(lightWarningKey) === "true";
        } catch {
          return false;
        }
      }

      function showLightModeWarning() {
        const dialog = document.getElementById("light-mode-warning");
        if (!dialog) return;
        const checkbox = document.getElementById("dismiss-light-warning");
        if (checkbox instanceof HTMLInputElement) checkbox.checked = false;
        dialog.showModal();
      }

      applyTheme(getTheme());

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const toggle = target.closest("[data-theme-toggle]");
        if (toggle instanceof HTMLButtonElement) {
          const currentTheme = document.documentElement.dataset.theme;
          if (currentTheme === "dark") {
            if (isLightWarningDismissed()) {
              setTheme("light");
            } else {
              showLightModeWarning();
            }
          } else {
            setTheme("dark");
          }
          return;
        }

        const postCard = target.closest("[data-post-card]");
        if (!(postCard instanceof HTMLElement)) return;
        if (target.closest("a, button, input, textarea, select, summary")) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

        const href = postCard.dataset.postUrl;
        if (!href) return;

        window.location.assign(href);
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (target.id === "light-mode-confirm" || target.closest("#light-mode-confirm")) {
          const checkbox = document.getElementById("dismiss-light-warning");
          if (checkbox instanceof HTMLInputElement && checkbox.checked) {
            try { window.localStorage.setItem(lightWarningKey, "true"); } catch {}
          }
          setTheme("light");
          const dialog = document.getElementById("light-mode-warning");
          if (dialog) dialog.close();
          return;
        }

        if (target.id === "light-mode-stay" || target.closest("#light-mode-stay")) {
          const dialog = document.getElementById("light-mode-warning");
          if (dialog) dialog.close();
          return;
        }
      });

      document.addEventListener("astro:after-swap", syncThemeToggle);
      document.addEventListener("astro:page-load", syncThemeToggle);
      document.addEventListener("DOMContentLoaded", syncThemeToggle);
    </script>

    <title>{title}</title>
    <slot name="head" />
    <ClientRouter />

    {import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID && (
      <script>
        import "../firebase/client";
      </script>
    )}
  </head>
  <body class="bg-base-100 text-base-content antialiased">
    <Header />
    <main class="pb-16">
      <slot />
    </main>

    <dialog id="light-mode-warning" class="modal">
      <div class="modal-box max-w-md">
        <h3 class="text-lg font-semibold">Switch to light mode?</h3>
        <p class="text-base-content/70 mt-2 text-sm leading-relaxed">
          Light mode can cause eye strain in dark environments. The change is instant and may feel jarring.
        </p>
        <div class="mt-4 flex items-center gap-2">
          <input type="checkbox" id="dismiss-light-warning" class="checkbox checkbox-sm checkbox-primary" />
          <label for="dismiss-light-warning" class="text-base-content/60 cursor-pointer text-sm">Don't show this again</label>
        </div>
        <div class="modal-action">
          <button type="button" id="light-mode-stay" class="btn btn-ghost btn-sm">Stay in dark</button>
          <button type="button" id="light-mode-confirm" class="btn btn-primary btn-sm">Switch to light</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>

    <Footer />

    <NewsletterModal siteKey={import.meta.env.TURNSTILE_SITE_KEY || ""} />
  </body>
</html>
