---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "hmziq.rs",
  description = "A blog about software engineering.",
  image,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image ?? "/og-default.svg", Astro.site);
---

<!doctype html>
<html lang="en" data-theme="night">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="hmziq.rs" href="/rss.xml" />

    <script is:inline>
      const themeKey = "theme";
      const defaultTheme = "night";

      function getTheme() {
        try {
          const savedTheme = window.localStorage.getItem(themeKey);
          return savedTheme === "light" || savedTheme === "night" ? savedTheme : defaultTheme;
        } catch {
          return defaultTheme;
        }
      }

      function applyTheme(theme) {
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme === "night" ? "dark" : "light";

        document.querySelectorAll("[data-theme-toggle]").forEach((toggle) => {
          toggle.textContent = theme === "night" ? "Light mode" : "Dark mode";
          toggle.setAttribute("aria-pressed", String(theme === "light"));
        });
      }

      function setTheme(theme) {
        applyTheme(theme);
        try {
          window.localStorage.setItem(themeKey, theme);
        } catch {}
      }

      function syncThemeToggle() {
        applyTheme(getTheme());
      }

      applyTheme(getTheme());

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const toggle = target.closest("[data-theme-toggle]");
        if (!(toggle instanceof HTMLButtonElement)) return;

        setTheme(document.documentElement.dataset.theme === "night" ? "light" : "night");
      });

      document.addEventListener("astro:page-load", syncThemeToggle);
      document.addEventListener("DOMContentLoaded", syncThemeToggle);
    </script>

    <title>{title}</title>
    <slot name="head" />
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
