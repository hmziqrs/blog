---
import { getCollection } from "astro:content";
import { pageTitle, routes } from "../config/site";
import BadgeLink from "../components/BadgeLink.astro";
import PageContainer from "../components/PageContainer.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { countSortedValues } from "../utils/posts";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const categories = countSortedValues(posts.map((post) => post.data.category));
---

<BaseLayout title={pageTitle("Categories")} description="Browse posts by category.">
  <PageContainer>
    <PageHeader
      title="Categories"
      description="Browse posts grouped by broad topic."
      class="mb-8"
    />
    {
      categories.length === 0 ? (
        <p class="text-base-content/40 text-sm">No categories yet.</p>
      ) : (
        <div class="flex flex-wrap gap-3">
          {categories.map(([category, count]) => (
            <BadgeLink
              href={routes.category(category)}
              variant="accent"
              size="lg"
              class="capitalize gap-2"
            >
              {category}
              <span class="opacity-65">{count}</span>
            </BadgeLink>
          ))}
        </div>
      )
    }
  </PageContainer>
</BaseLayout>
