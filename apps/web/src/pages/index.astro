---
import { getCollection } from "astro:content";
import { siteConfig } from "../config/site";
import AdvertisementBanner from "../components/AdvertisementBanner.astro";
import PageContainer from "../components/PageContainer.astro";
import PostList from "../components/PostList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.name,
    url: siteConfig.publicSiteUrl,
    description: siteConfig.blog.homeDescription,
    inLanguage: "en-US",
  },
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: siteConfig.name,
    url: siteConfig.publicSiteUrl,
    description: siteConfig.blog.homeDescription,
    inLanguage: "en-US",
  },
];
---

<BaseLayout
  title={siteConfig.name}
  description={siteConfig.blog.homeDescription}
  structuredData={structuredData}
>
  <PageContainer>
    <AdvertisementBanner
      href={siteConfig.advertisement?.href || ""}
      imageUrl={siteConfig.advertisement?.imageUrl}
      alt={siteConfig.advertisement?.alt}
      title={siteConfig.advertisement?.title}
      description={siteConfig.advertisement?.description}
    />
    <PostList posts={posts} emptyMessage="No posts yet. Check back soon." />
  </PageContainer>
</BaseLayout>
