---
import { pageTitle, siteConfig } from "../config/site";
import PageContainer from "../components/PageContainer.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const contactPage = siteConfig.pages.contact;
---

{
  contactPage ? (
    <BaseLayout title={pageTitle(contactPage.title)} description={`How to get in touch with ${siteConfig.name}.`}>
      <PageContainer>
        <PageHeader title={contactPage.title} description={contactPage.description} class="mb-8" />

        <section class="grid max-w-3xl gap-4">
          {
            contactPage.sections.map((section) => (
              <article
                class:list={[
                  "rounded-[1.25rem] border border-base-300 p-5 sm:p-6",
                  section.tone === "subtle" ? "bg-base-200/55" : "bg-base-100/70",
                ]}
              >
                <p class="mb-3 font-mono text-[0.72rem] uppercase tracking-[0.16em] text-base-content/52">
                  {section.label}
                </p>
                <p class="text-base leading-7 text-base-content/78">{section.body}</p>
              </article>
            ))
          }
        </section>
      </PageContainer>
    </BaseLayout>
  ) : (
    <BaseLayout title={pageTitle("404")} description="Page not found." noindex>
      <PageContainer>
        <PageHeader title="Page not found" description="This page is not enabled for this site." />
      </PageContainer>
    </BaseLayout>
  )
}
