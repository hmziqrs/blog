---
import { pageTitle, siteConfig } from "../config/site";
import PageContainer from "../components/PageContainer.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const termsPage = siteConfig.pages.terms;
---

{
  termsPage ? (
    <BaseLayout title={pageTitle(termsPage.title)} description={`Terms for using ${siteConfig.name}.`}>
      <PageContainer>
        <PageHeader title={termsPage.title} description={termsPage.description} class="mb-8" />
        <article class="prose legal-doc max-w-3xl">
          <div class="not-prose mb-8 flex flex-wrap items-center gap-3">
            <span class="rounded-full border border-base-300 bg-base-200 px-3 py-1 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-base-content/62">
              {termsPage.badgeLabel}
            </span>
            <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-base-content/48">
              Effective {termsPage.effectiveDate}
            </span>
          </div>

          <p>{termsPage.intro.replaceAll("this site", siteConfig.name)}</p>

          {
            termsPage.sections.map((section) => (
              <>
                <h2>{section.title}</h2>
                <p>{section.body.replaceAll("this site", siteConfig.name)}</p>
              </>
            ))
          }
        </article>
      </PageContainer>
    </BaseLayout>
  ) : (
    <BaseLayout title={pageTitle("404")} description="Page not found." noindex>
      <PageContainer>
        <PageHeader title="Page not found" description="This page is not enabled for this site." />
      </PageContainer>
    </BaseLayout>
  )
}
