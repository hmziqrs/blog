---
import { pageTitle, routes } from "../config/site";
import ButtonLink from "../components/ButtonLink.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={pageTitle("500")} description="Server error." noindex>
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="text-base-content/20 mb-4 text-9xl font-black">500</h1>
    <p class="mb-2 text-2xl font-semibold">Server error</p>
    <p class="text-base-content/60 mb-8">
      Something went wrong on our end. Please try again in a moment.
    </p>
    <ButtonLink href={routes.home} variant="primary">Back to home</ButtonLink>
  </div>
</BaseLayout>
