---
import { getCollection } from "astro:content";
import { pageTitle, siteConfig } from "../config/site";
import NewsletterForm from "../components/NewsletterForm.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageContainer from "../components/PageContainer.astro";

const title = pageTitle("Newsletter");
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "";

const issues = await getCollection("newsletters");
issues.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={title} description="Subscribe to the Hmziq blog newsletter">
  <PageContainer>
    <main class="max-w-2xl mx-auto px-4 py-12">
      <h1 class="text-3xl font-bold mb-6">Newsletter</h1>

      <div class="bg-base-100 rounded-lg shadow p-6 mb-8 border border-base-content/10">
        <h2 class="text-xl font-semibold mb-4">Subscribe to the Newsletter</h2>
        <p class="text-base-content/70 mb-6">
          Get notified when new posts are published. No spam, unsubscribe anytime.
        </p>

        <NewsletterForm siteKey={siteKey} />
      </div>

      <div class="bg-base-200/60 rounded-lg p-6 border border-base-content/10">
        <h3 class="font-semibold mb-2">What you'll receive:</h3>
        <ul class="list-disc list-inside text-base-content/70 space-y-1">
          <li>New post notifications</li>
          <li>Curated content summaries</li>
          <li>Occasional updates</li>
        </ul>

        <p class="text-sm text-base-content/50 mt-4">
          By subscribing, you agree to our
          <a href="/privacy" class="text-primary hover:underline"
            >Privacy Policy</a
          >.
        </p>
      </div>

      {
        issues.length > 0 && (
          <div class="mt-12">
            <h2 class="text-lg font-semibold mb-4">Past issues</h2>
            <ul class="space-y-3">
              {issues.map((issue) => {
                const dateStr = issue.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                });
                return (
                  <li>
                    <a
                      href={`/newsletter/${issue.id}`}
                      class="group flex items-baseline justify-between gap-4 rounded-lg border border-base-content/10 bg-base-100 px-4 py-3 hover:border-base-content/20 hover:bg-base-200/40 transition-all"
                    >
                      <span class="text-sm font-medium group-hover:text-primary transition-colors">
                        {issue.data.title}
                      </span>
                      <time
                        class="font-mono text-[0.65rem] uppercase tracking-[0.1em] text-base-content/35 shrink-0"
                        datetime={issue.data.date.toISOString()}
                      >
                        {dateStr}
                      </time>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )
      }
    </main>
  </PageContainer>
</BaseLayout>

<script is:inline>
  // Load Cloudflare Turnstile script
  const script = document.createElement("script");
  script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js";
  script.async = true;
  script.defer = true;
  document.head.appendChild(script);
</script>
