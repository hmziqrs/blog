---
import { pageTitle, siteConfig } from "../config/site";
import PageContainer from "../components/PageContainer.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const aboutPage = siteConfig.pages.about;
---

{
  aboutPage ? (
    <BaseLayout title={pageTitle(aboutPage.title)} description={aboutPage.description}>
      <PageContainer>
        <PageHeader title={aboutPage.title} class="mb-6" />
        <article class="prose max-w-2xl">
          {aboutPage.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </article>
      </PageContainer>
    </BaseLayout>
  ) : (
    <BaseLayout title={pageTitle("404")} description="Page not found." noindex>
      <PageContainer>
        <PageHeader title="Page not found" description="This page is not enabled for this site." />
      </PageContainer>
    </BaseLayout>
  )
}
