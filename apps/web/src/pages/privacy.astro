---
import { pageTitle, routes, siteConfig } from "../config/site";
import PageContainer from "../components/PageContainer.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const privacyPage = siteConfig.pages.privacy;
---

{
  privacyPage ? (
    <BaseLayout title={pageTitle(privacyPage.title)} description={`Privacy policy for ${siteConfig.name}.`}>
      <PageContainer>
        <PageHeader title={privacyPage.title} description={privacyPage.description} class="mb-8" />
        <article class="prose legal-doc max-w-3xl">
          <div class="not-prose mb-8 flex flex-wrap items-center gap-3">
            <span class="rounded-full border border-base-300 bg-base-200 px-3 py-1 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-base-content/62">
              {privacyPage.badgeLabel}
            </span>
            <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-base-content/48">
              Effective {privacyPage.effectiveDate}
            </span>
          </div>

          <p>{privacyPage.intro.replaceAll("this site", siteConfig.name)}</p>

          {
            privacyPage.sections.map((section) => (
              <>
                <h2>{section.title}</h2>
                {
                  section.title === "Contact" ? (
                    <p>
                      If you have a privacy-related question about {siteConfig.name}, use the details
                      listed on the <a href={routes.contact}>contact page</a>. Material changes to this
                      page may be reflected here by updating the effective date.
                    </p>
                  ) : (
                    <p>{section.body.replaceAll("this site", siteConfig.name)}</p>
                  )
                }
              </>
            ))
          }
        </article>
      </PageContainer>
    </BaseLayout>
  ) : (
    <BaseLayout title={pageTitle("404")} description="Page not found." noindex>
      <PageContainer>
        <PageHeader title="Page not found" description="This page is not enabled for this site." />
      </PageContainer>
    </BaseLayout>
  )
}
