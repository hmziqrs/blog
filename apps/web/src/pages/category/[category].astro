---
import { getCollection } from "astro:content";
import { pageTitle } from "@blog/site";
import CategoryNav from "../../components/CategoryNav.astro";
import PageContainer from "../../components/PageContainer.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((category) => ({
    params: { category },
    props: { posts: posts.filter((p) => p.data.category === category) },
  }));
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<"posts">>>;
}

const { category } = Astro.params;
const { posts } = Astro.props;
const sorted = posts.toSorted((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title={pageTitle(category)}
  description={`Posts in the ${category} category.`}
>
  <PageContainer>
    <PageHeader
      title={category}
      titleClass="mb-6 text-4xl font-semibold tracking-tight capitalize sm:text-5xl"
    />
    <div class="mb-8">
      <CategoryNav active={category} />
    </div>
    <div class="flex flex-col gap-5">
      {sorted.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          tags={post.data.tags}
          category={post.data.category}
        />
      ))}
    </div>
  </PageContainer>
</BaseLayout>
