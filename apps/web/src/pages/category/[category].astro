---
import { getCollection } from "astro:content";
import { pageTitle } from "../../config/site";
import CategoryNav from "../../components/CategoryNav.astro";
import PageContainer from "../../components/PageContainer.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostList from "../../components/PostList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectSortedValues } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const categories = collectSortedValues(posts.map((post) => post.data.category));
  return categories.map((category) => ({
    params: { category: encodeURIComponent(category) },
    props: {
      posts: posts.filter((p) => p.data.category === category),
      categories,
      category,
    },
  }));
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<"posts">>>;
  categories: string[];
  category: string;
}

const { posts, categories, category } = Astro.props as Props;
---

<BaseLayout
  title={pageTitle(category)}
  description={`Posts in the ${category} category.`}
>
  <PageContainer>
    <PageHeader
      title={category}
      titleClass="mb-6 text-4xl font-semibold tracking-tight capitalize sm:text-5xl"
    />
    <div class="mb-8">
      <CategoryNav active={category} categories={categories} />
    </div>
    <PostList posts={posts} />
  </PageContainer>
</BaseLayout>
