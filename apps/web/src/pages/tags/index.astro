---
import { getCollection } from "astro:content";
import { pageTitle, siteConfig } from "../../config/site";
import PageContainer from "../../components/PageContainer.astro";
import PageHeader from "../../components/PageHeader.astro";
import TagBadge from "../../components/TagBadge.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { countSortedValues } from "../../utils/posts";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const tags = countSortedValues(posts.flatMap((post) => post.data.tags));
---

<BaseLayout
  title={pageTitle("Tags")}
  description={`Browse ${tags.length} recurring topics on ${siteConfig.name}.`}
>
  <PageContainer>
    <PageHeader
      title="Tags"
      description="An index of recurring topics across the site, from tools and systems to product and writing."
      class="mb-8"
    />
    {
      tags.length === 0 ? (
        <p class="text-base-content/40 text-sm">No tags yet.</p>
      ) : (
        <div class="flex flex-wrap gap-3">
          {tags.map(([tag, count]) => (
            <TagBadge tag={tag} count={count} size="large" />
          ))}
        </div>
      )
    }
  </PageContainer>
</BaseLayout>
