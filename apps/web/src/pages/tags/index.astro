---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const tagCounts = posts.flatMap((p) => p.data.tags).reduce<Record<string, number>>((acc, tag) => {
  acc[tag] = (acc[tag] ?? 0) + 1;
  return acc;
}, {});

const tags = Object.entries(tagCounts).toSorted(([a], [b]) => a.localeCompare(b));
---

<BaseLayout title="Tags — hmziq.rs" description="Browse posts by tag.">
  <div class="container mx-auto max-w-3xl px-4 py-10">
    <h1 class="mb-8 text-3xl font-bold">Tags</h1>
    {
      tags.length === 0 ? (
        <p class="text-base-content/40 text-sm">No tags yet.</p>
      ) : (
        <div class="flex flex-wrap gap-3">
          {tags.map(([tag, count]) => (
            <a
              href={`/tags/${tag}`}
              class="badge badge-outline badge-lg hover:badge-primary gap-1.5 transition-colors"
            >
              #{tag}
              <span class="opacity-50">{count}</span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
