---
import { getCollection } from "astro:content";
import PageContainer from "../../components/PageContainer.astro";
import PageHeader from "../../components/PageHeader.astro";
import TagBadge from "../../components/TagBadge.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const tagCounts = posts.flatMap((p) => p.data.tags).reduce<Record<string, number>>((acc, tag) => {
  acc[tag] = (acc[tag] ?? 0) + 1;
  return acc;
}, {});

const tags = Object.entries(tagCounts).toSorted(([a], [b]) => a.localeCompare(b));
---

<BaseLayout title="Tags — hmziq.rs" description="Browse posts by tag.">
  <PageContainer>
    <PageHeader title="Tags" class="mb-8" />
    {
      tags.length === 0 ? (
        <p class="text-base-content/40 text-sm">No tags yet.</p>
      ) : (
        <div class="flex flex-wrap gap-3">
          {tags.map(([tag, count]) => (
            <TagBadge tag={tag} count={count} size="large" />
          ))}
        </div>
      )
    }
  </PageContainer>
</BaseLayout>
