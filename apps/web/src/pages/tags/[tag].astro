---
import { getCollection } from "astro:content";
import { pageTitle } from "../../config/site";
import PageContainer from "../../components/PageContainer.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostList from "../../components/PostList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectSortedValues } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const tags = collectSortedValues(posts.flatMap((post) => post.data.tags));
  return tags.map((tag) => ({
    params: { tag: encodeURIComponent(tag) },
    props: {
      posts: posts.filter((p) => p.data.tags.includes(tag)),
      tag,
    },
  }));
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<"posts">>>;
  tag: string;
}

const { posts, tag } = Astro.props as Props;
---

<BaseLayout title={pageTitle(`#${tag}`)} description={`Posts tagged with #${tag}.`}>
  <PageContainer>
    <PageHeader title={`#${tag}`} class="mb-8">
      <p class="text-base-content/48 text-sm leading-6">
        {posts.length}
        {posts.length === 1 ? "post" : "posts"}
      </p>
    </PageHeader>
    <PostList posts={posts} />
  </PageContainer>
</BaseLayout>
