---
import type { AboutPageConfig, ContactPageConfig, LegalPageConfig } from "@blog/site";
import { pageTitle, routes, siteConfig } from "../config/site";
import ButtonLink from "../components/ButtonLink.astro";
import ContactPlatformIcon from "../components/ContactPlatformIcon.astro";
import InlineNewsletter from "../components/InlineNewsletter.astro";
import PageContainer from "../components/PageContainer.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

type OptionalPageEntry =
  | { page: "about"; config: AboutPageConfig }
  | { page: "contact"; config: ContactPageConfig }
  | { page: "privacy"; config: LegalPageConfig }
  | { page: "terms"; config: LegalPageConfig };

export function getStaticPaths() {
  const optionalPages: OptionalPageEntry[] = [];

  if (siteConfig.pages.about) {
    optionalPages.push({ page: "about", config: siteConfig.pages.about });
  }
  if (siteConfig.pages.contact) {
    optionalPages.push({ page: "contact", config: siteConfig.pages.contact });
  }
  if (siteConfig.pages.privacy) {
    optionalPages.push({ page: "privacy", config: siteConfig.pages.privacy });
  }
  if (siteConfig.pages.terms) {
    optionalPages.push({ page: "terms", config: siteConfig.pages.terms });
  }

  return optionalPages.map(({ page, config }) => ({
    params: { page },
    props: { page, config },
  }));
}

const { page, config } = Astro.props as OptionalPageEntry;
const aboutPage = page === "about" ? (config as AboutPageConfig) : null;
const contactPage = page === "contact" ? (config as ContactPageConfig) : null;
const legalPage =
  page === "privacy" || page === "terms" ? (config as LegalPageConfig) : null;

const aboutParagraphs = aboutPage?.paragraphs ?? [];
const contactParagraphs = contactPage?.paragraphs ?? [];
const legalPreamble = legalPage?.preamble ?? [];
const contactMethods = contactPage?.methods ?? [];
---

<BaseLayout title={pageTitle(config.title)} description={config.description}>
  <PageContainer>
    {
      aboutPage ? (
        <section class="max-w-3xl">
          <div class="max-w-2xl space-y-4 text-base leading-7 text-base-content sm:text-[1.02rem]">
            {aboutParagraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-2">
            <ButtonLink href={routes.tags} size="sm" class="font-mono uppercase tracking-[0.14em]">
              Tags
            </ButtonLink>
            <ButtonLink
              href={routes.categories}
              variant="primary"
              size="sm"
              class="font-mono uppercase tracking-[0.14em]"
            >
              Categories
            </ButtonLink>
          </div>

          <div class="mt-12">
            <InlineNewsletter
              siteKey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || ""}
              uid="about-newsletter"
            />
          </div>
        </section>
      ) : contactPage ? (
        <>
          <section class="max-w-3xl">
            <div class="max-w-2xl space-y-3 text-base leading-7 text-base-content/78 sm:text-[1.02rem]">
              {contactParagraphs.map((paragraph, index) => (
                <p class:list={[index === contactParagraphs.length - 1 && "text-base-content"]}>
                  {paragraph}
                </p>
              ))}
            </div>

            <div class="mt-12 space-y-2.5 max-w-md">
              {
                contactMethods.map((method) => (
                  <a
                    href={method.href}
                    target={method.href.startsWith("http") ? "_blank" : undefined}
                    rel={method.href.startsWith("http") ? "noreferrer" : undefined}
                    class="group flex items-center gap-3 rounded-xl border border-base-content/8 bg-base-100 px-5 py-3.5 hover:border-base-content/16 hover:bg-base-200/30 transition-all duration-200"
                  >
                    <ContactPlatformIcon platform={method.label} class="h-5 w-5 shrink-0 text-base-content/50 group-hover:text-primary transition-colors" />
                    <div class="min-w-0">
                      <div class="text-[0.64rem] font-mono font-semibold uppercase tracking-[0.18em] text-base-content/35">{method.label}</div>
                      <div class="text-sm text-base-content/78 group-hover:text-base-content truncate">{method.value}</div>
                    </div>
                    <span class="ml-auto text-base-content/16 group-hover:text-primary group-hover:translate-x-1 transition-all text-xs">&rarr;</span>
                  </a>
                ))
              }
            </div>
          </section>
        </>
      ) : legalPage ? (
        <>
          <PageHeader title={config.title} description={config.description} class="mb-8" />
          <article class="prose legal-doc max-w-3xl">
            <div class="not-prose mb-8 flex flex-wrap items-center gap-3">
              <span class="rounded-full border border-base-300 bg-base-200 px-3 py-1 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-base-content/62">
                {legalPage.badgeLabel}
              </span>
              <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-base-content/48">
                Effective {legalPage.effectiveDate}
              </span>
            </div>

            {legalPreamble.map((paragraph) => <p>{paragraph.replaceAll("this site", siteConfig.name)}</p>)}

            {
              legalPage.sections.map((section) => (
                <>
                  <h2>{section.title}</h2>
                  {
                    page === "privacy" && section.title === "Contact" && siteConfig.pages.contact ? (
                      <p>
                        If you have a privacy-related question about {siteConfig.name}, use the details
                        listed on the <a href={routes.contact}>contact page</a>. Material changes to this
                        page may be reflected here by updating the effective date.
                      </p>
                    ) : (
                      <p>{section.body.replaceAll("this site", siteConfig.name)}</p>
                    )
                  }
                </>
              ))
            }
          </article>
        </>
      ) : null
    }
  </PageContainer>
</BaseLayout>
