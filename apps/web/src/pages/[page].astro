---
import type { AboutPageConfig, ContactPageConfig, LegalPageConfig } from "@blog/site";
import { pageTitle, routes, siteConfig } from "../config/site";
import ButtonLink from "../components/ButtonLink.astro";
import ContactPlatformIcon from "../components/ContactPlatformIcon.astro";
import PageContainer from "../components/PageContainer.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

type OptionalPageEntry =
  | { page: "about"; config: AboutPageConfig }
  | { page: "contact"; config: ContactPageConfig }
  | { page: "privacy"; config: LegalPageConfig }
  | { page: "terms"; config: LegalPageConfig };

export function getStaticPaths() {
  const optionalPages: OptionalPageEntry[] = [];

  if (siteConfig.pages.about) {
    optionalPages.push({ page: "about", config: siteConfig.pages.about });
  }
  if (siteConfig.pages.contact) {
    optionalPages.push({ page: "contact", config: siteConfig.pages.contact });
  }
  if (siteConfig.pages.privacy) {
    optionalPages.push({ page: "privacy", config: siteConfig.pages.privacy });
  }
  if (siteConfig.pages.terms) {
    optionalPages.push({ page: "terms", config: siteConfig.pages.terms });
  }

  return optionalPages.map(({ page, config }) => ({
    params: { page },
    props: { page, config },
  }));
}

const { page, config } = Astro.props as OptionalPageEntry;
const aboutPage = page === "about" ? (config as AboutPageConfig) : null;
const contactPage = page === "contact" ? (config as ContactPageConfig) : null;
const legalPage =
  page === "privacy" || page === "terms" ? (config as LegalPageConfig) : null;

const contactParagraphs =
  contactPage && "paragraphs" in contactPage && Array.isArray(contactPage.paragraphs)
    ? contactPage.paragraphs
    : [];

const contactMethods =
  contactPage && "methods" in contactPage && Array.isArray(contactPage.methods)
    ? contactPage.methods
    : [];
---

<BaseLayout title={pageTitle(config.title)} description={config.description}>
  <PageContainer>
    {
      aboutPage ? (
        <>
          <section class="page-hero mb-10 overflow-hidden px-6 py-8 sm:px-8 sm:py-10">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1.22fr)_minmax(18rem,0.88fr)] lg:items-start">
              <div>
                <p class="page-kicker mb-4">Profile</p>
                <h1 class="max-w-3xl text-4xl font-semibold tracking-tight sm:text-5xl">
                  {aboutPage.title}
                </h1>
                <p class="mt-4 max-w-2xl text-base leading-7 text-base-content/68 sm:text-[1.05rem]">
                  {aboutPage.description}
                </p>
                <article class="prose mt-8 max-w-none sm:mt-10">
                  {aboutPage.intro.map((paragraph) => <p>{paragraph}</p>)}
                </article>
              </div>

              <aside class="page-panel p-5 sm:p-6 lg:mt-1">
                <p class="page-kicker mb-4">What this site optimizes for</p>
                <ul class="page-list text-sm leading-6 sm:text-[0.95rem]">
                  {aboutPage.principles.map((principle) => <li>{principle}</li>)}
                </ul>
              </aside>
            </div>
          </section>

          <section class="grid gap-4 md:grid-cols-3">
            {
              aboutPage.focusAreas.map((section, index) => (
                <article class:list={["page-panel h-full p-5 sm:p-6", index === 1 && "bg-base-200/80"]}>
                  <p class="page-kicker mb-3">0{index + 1}</p>
                  <h2 class="text-xl font-semibold tracking-tight">{section.title}</h2>
                  <p class="mt-3 text-sm leading-6 text-base-content/74 sm:text-[0.95rem]">
                    {section.body}
                  </p>
                </article>
              ))
            }
          </section>

          <section class="page-panel mt-6 flex flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-7">
            <div class="max-w-2xl">
              <p class="page-kicker mb-2">Explore the archive</p>
              <p class="text-sm leading-6 text-base-content/72 sm:text-[0.95rem]">
                Browse posts by topic or category if you want the fastest read on what the site is
                covering right now.
              </p>
            </div>

            <div class="flex flex-wrap gap-2">
              <ButtonLink
                href={routes.tags}
                size="sm"
                class="font-mono uppercase tracking-[0.14em]"
              >
                Tags
              </ButtonLink>
              <ButtonLink
                href={routes.categories}
                variant="primary"
                size="sm"
                class="font-mono uppercase tracking-[0.14em]"
              >
                Categories
              </ButtonLink>
            </div>
          </section>
        </>
      ) : contactPage ? (
        <>
          <section class="max-w-3xl">
            <PageHeader title={contactPage.title} class="mb-8" />
            <div class="max-w-2xl space-y-3 text-base leading-7 text-base-content/78 sm:text-[1.02rem]">
              {contactParagraphs.map((paragraph, index) => (
                <p class:list={[index === contactParagraphs.length - 1 && "text-base-content"]}>
                  {paragraph}
                </p>
              ))}
            </div>

            <div class="mt-8 grid grid-cols-3 gap-3 sm:grid-cols-2">
              {
                contactMethods.map((method) => (
                  <a
                    href={method.href}
                    class="group flex min-w-0 flex-col items-center justify-center gap-2 rounded-[1.1rem] border border-base-content/10 bg-base-200/60 px-3 py-3.5 text-center transition-[border-color,background-color,color,transform] duration-200 hover:-translate-y-px hover:border-primary/35 hover:bg-base-200/80 hover:text-primary sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-4 sm:py-[0.95rem] sm:text-left"
                    target={method.href.startsWith("http") ? "_blank" : undefined}
                    rel={method.href.startsWith("http") ? "noreferrer" : undefined}
                  >
                    <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-base-content/10 bg-base-100/70 text-base-content/82 transition-[border-color,color,background-color] duration-200 group-hover:border-primary/35 group-hover:bg-primary/8 group-hover:text-primary sm:order-2 sm:h-10 sm:w-10">
                      <ContactPlatformIcon platform={method.label} />
                    </span>
                    <div class="min-w-0 sm:order-1 sm:flex-1">
                      <p class="hidden font-mono text-[0.68rem] font-semibold tracking-[0.16em] text-base-content/48 uppercase sm:block">
                        {method.label}
                      </p>
                      <p class="mt-0.5 overflow-hidden text-ellipsis whitespace-nowrap text-sm font-medium tracking-[-0.02em] text-base-content sm:text-base">
                        {method.value}
                      </p>
                    </div>
                  </a>
                ))
              }
            </div>
          </section>
        </>
      ) : legalPage ? (
        <>
          <PageHeader title={config.title} description={config.description} class="mb-8" />
          <article class="prose legal-doc max-w-3xl">
            <div class="not-prose mb-8 flex flex-wrap items-center gap-3">
              <span class="rounded-full border border-base-300 bg-base-200 px-3 py-1 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-base-content/62">
                {legalPage.badgeLabel}
              </span>
              <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-base-content/48">
                Effective {legalPage.effectiveDate}
              </span>
            </div>

            <p>{legalPage.intro.replaceAll("this site", siteConfig.name)}</p>

            {
              legalPage.sections.map((section) => (
                <>
                  <h2>{section.title}</h2>
                  {
                    page === "privacy" && section.title === "Contact" && siteConfig.pages.contact ? (
                      <p>
                        If you have a privacy-related question about {siteConfig.name}, use the details
                        listed on the <a href={routes.contact}>contact page</a>. Material changes to this
                        page may be reflected here by updating the effective date.
                      </p>
                    ) : (
                      <p>{section.body.replaceAll("this site", siteConfig.name)}</p>
                    )
                  }
                </>
              ))
            }
          </article>
        </>
      ) : null
    }
  </PageContainer>
</BaseLayout>
