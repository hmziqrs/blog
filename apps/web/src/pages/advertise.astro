---
import { pageTitle, siteConfig } from "../config/site";
import PageContainer from "../components/PageContainer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import InteractiveCanvasBanner from "../components/InteractiveCanvasBanner.astro";
import ThreeJSBanner from "../components/ThreeJSBanner.astro";
---

<BaseLayout
  title={pageTitle("Advertise")}
  description="Advertising guidelines and sponsorship opportunities."
>
  <PageContainer>
    <div class="max-w-3xl space-y-6">
      <h2 class="text-xl font-semibold">What We Don't Accept</h2>
      <p>Gambling, harmful substances or addictive products, scams, and misleading content.</p>

      <h2 class="text-xl font-semibold">Banner Types</h2>
      <p>Static image banners. Interactive canvas banners with subtle animations. 3D Web Component banners using Three.js.</p>

      <h2 class="text-xl font-semibold">Interactive Canvas Example</h2>
      <p>Here's an example of a beautiful interactive canvas banner with particle effects and mouse interaction:</p>
      
      <InteractiveCanvasBanner 
        title="Your Brand Here" 
        subtitle="Interactive Canvas Banner" 
      />

      <h2 class="text-xl font-semibold">3D Web Component Example</h2>
      <p>Here's an example of a 3D interactive banner with Three.js, featuring floating particles, interactive 3D shapes, and mouse interactions:</p>
      
      <ThreeJSBanner 
        brandName="Your Brand Here"
        ctaText="Learn More"
        ctaUrl="/contact"
        modelType="cube"
        particleCount={150}
      />

      <h2 class="text-xl font-semibold">Payment</h2>
      <p>Fiat and cryptocurrency.</p>

      <h2 class="text-xl font-semibold">Get Started</h2>
      <p>
        <a href="/contact" class="text-primary hover:underline">Use the contact page</a> to discuss
        advertising.
      </p>
    </div>
  </PageContainer>
</BaseLayout>
