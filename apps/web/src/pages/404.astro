---
import { pageTitle } from "@blog/site";
import ButtonLink from "../components/ButtonLink.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={pageTitle("404")} description="Page not found." noindex>
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="text-base-content/20 mb-4 text-9xl font-black">404</h1>
    <p class="mb-2 text-2xl font-semibold">Page not found</p>
    <p class="text-base-content/60 mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <ButtonLink href="/" variant="primary">Back to home</ButtonLink>
  </div>
</BaseLayout>
