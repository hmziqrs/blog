---
import { routes } from "../config/site";
import BadgeLink from "./BadgeLink.astro";

interface Props {
  category: string;
  variant?: "ghost" | "outline" | "accent";
  class?: string;
}

const { category, variant = "accent", class: className } = Astro.props;
---

<BadgeLink
  href={routes.category(category)}
  variant={variant}
  size="sm"
  class={className ? `capitalize ${className}` : "capitalize"}
>
  {category}
</BadgeLink>
