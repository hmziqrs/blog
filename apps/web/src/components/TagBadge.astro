---
import { routes } from "../config/site";
import BadgeLink from "./BadgeLink.astro";

interface Props {
  tag: string;
  count?: number;
  size?: "default" | "large";
  class?: string;
}

const { tag, count, size = "default", class: className } = Astro.props;

const badgeClass = [
  size === "large" ? "gap-1.5" : "",
  className ?? "",
].filter(Boolean).join(" ");
---

<BadgeLink
  href={routes.tag(tag)}
  size={size === "large" ? "lg" : "md"}
  class={badgeClass}
>
  #{tag}
  {typeof count === "number" && <span class="opacity-50">{count}</span>}
</BadgeLink>
