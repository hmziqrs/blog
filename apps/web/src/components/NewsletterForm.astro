---
const { siteKey = "", uid = "newsletter" } = Astro.props;
---

<form id={`${uid}-form`} class="flex flex-col gap-3">
  <div>
    <label for={`${uid}-email`} class="block text-sm font-medium mb-1">
      Email address
    </label>
    <input
      type="email"
      id={`${uid}-email`}
      name="email"
      required
      placeholder="you@example.com"
      class="w-full px-4 py-2.5 border border-base-content/15 rounded-xl bg-base-100/80 focus:ring-2 focus:ring-primary/50 focus:border-primary/40 text-base-content placeholder:text-base-content/40 transition-all"
    />
  </div>

  <div
    id={`${uid}-turnstile`}
    class="cf-turnstile"
    data-sitekey={siteKey}
  ></div>

  <button
    type="submit"
    id={`${uid}-submit`}
    class="w-full bg-primary text-primary-content font-semibold py-2.5 px-4 rounded-xl hover:bg-primary/90 active:scale-[0.98] transition-all disabled:opacity-50 disabled:cursor-not-allowed"
  >
    Subscribe
  </button>

  <div id={`${uid}-message`} class="text-sm hidden"></div>
</form>

<script define:vars={{ uid, apiBase: import.meta.env.PUBLIC_API_BASE ?? "" }}>
  import { isEmail } from "validator";

  const form = document.getElementById(`${uid}-form`);
  const submitBtn = document.getElementById(`${uid}-submit`);
  const message = document.getElementById(`${uid}-message`);
  const emailInput = document.getElementById(`${uid}-email`);
  const COOLDOWN_KEY = `${uid}-rate-limit-until`;

  function normalizeEmail(raw) {
    const atIndex = raw.lastIndexOf("@");
    if (atIndex === -1) return raw.toLowerCase().trim();
    const local = raw.slice(0, atIndex).toLowerCase().trim();
    const domain = raw.slice(atIndex + 1).toLowerCase().trim();
    const normalizedLocal = local.split("+")[0] ?? local;
    return `${normalizedLocal}@${domain}`;
  }

  function formatCooldown(seconds) {
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return m > 0 ? `${m}m ${s}s` : `${s}s`;
  }

  function startCooldown(remainingSec) {
    const until = Date.now() + remainingSec * 1000;
    localStorage.setItem(COOLDOWN_KEY, String(until));
    disableForm(remainingSec);
  }

  function disableForm(remainingSec) {
    submitBtn.disabled = true;
    if (emailInput) emailInput.disabled = true;
    showMessage(`Too many attempts. Try again in ${formatCooldown(remainingSec)}.`, "error");

    const interval = setInterval(() => {
      const left = Math.ceil((Number(localStorage.getItem(COOLDOWN_KEY)) - Date.now()) / 1000);
      if (left <= 0) {
        clearInterval(interval);
        localStorage.removeItem(COOLDOWN_KEY);
        submitBtn.disabled = false;
        if (emailInput) emailInput.disabled = false;
        showMessage("", "info");
        message.classList.add("hidden");
        return;
      }
      showMessage(`Too many attempts. Try again in ${formatCooldown(left)}.`, "error");
    }, 1000);
  }

  // Restore cooldown on page load
  const savedUntil = Number(localStorage.getItem(COOLDOWN_KEY));
  if (savedUntil && savedUntil > Date.now()) {
    disableForm(Math.ceil((savedUntil - Date.now()) / 1000));
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const rawEmail = emailInput?.value?.trim() ?? "";
    if (!rawEmail || !isEmail(rawEmail)) {
      showMessage("Please enter a valid email address.", "error");
      return;
    }

    // Show the normalized form so the user knows what will be stored
    const normalized = normalizeEmail(rawEmail);
    if (normalized !== rawEmail) {
      showMessage(`Will subscribe as ${normalized}`, "info");
    }

    const turnstileResponse = document.querySelector(
      `#${uid}-turnstile input[name='cf-turnstile-response']`,
    )?.value;

    if (!turnstileResponse) {
      showMessage("Please complete the CAPTCHA", "error");
      return;
    }

    submitBtn.disabled = true;
    showMessage("Subscribing...", "info");

    try {
      const API_BASE = apiBase;
      const response = await fetch(`${API_BASE}/api/newsletter/subscribe`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email: rawEmail,
          token: turnstileResponse,
        }),
      });

      const data = await response.json();

      if (response.ok) {
        showMessage("Successfully subscribed! Check your email.", "success");
        form.reset();
        submitBtn.disabled = false;
        localStorage.setItem("newsletterSubscribed", "true");
        if (window.turnstile) {
          window.turnstile.reset(`#${uid}-turnstile`);
        }
      } else if (response.status === 429) {
        startCooldown(data.retryAfter || 3600);
        return;
      } else {
        showMessage(data.error || "Subscription failed", "error");
        submitBtn.disabled = false;
      }
    } catch (error) {
      showMessage("An error occurred. Please try again.", "error");
    } finally {
      if (!submitBtn.disabled) {
        submitBtn.disabled = false;
      }
    }
  });

  function showMessage(text, type) {
    message.textContent = text;
    message.className = "text-sm";
    message.classList.remove("hidden");

    if (type === "success") {
      message.classList.add("text-success");
    } else if (type === "error") {
      message.classList.add("text-error");
    } else {
      message.classList.add("text-info");
    }
  }
</script>
