---
const { siteKey = "", uid = "modal-newsletter" } = Astro.props;
---
<>
<div
  id={`${uid}-modal-backdrop`}
  class="fixed inset-0 z-40 hidden opacity-0 bg-base-100/5 backdrop-blur-[1.5px] transition-opacity duration-300"
>
</div>
<div id={`${uid}-modal`} class="fixed inset-0 z-50 hidden items-center justify-center opacity-0 transition-opacity duration-300">
    <div class="relative w-full max-w-md overflow-hidden rounded-xl border border-base-content/10 bg-base-200/60 p-6 backdrop-blur-xl">
    <button
      id={`${uid}-close`}
      class="absolute top-4 right-4 text-base-content/40 hover:text-base-content/70 text-xl leading-none transition-colors"
      aria-label="Close"
    >
      &times;
    </button>

    <h2 class="text-xl font-semibold">Subscribe to the Newsletter</h2>
    <p class="mt-1.5 text-sm text-base-content/60 leading-relaxed">
      Get notified when new posts are published. No spam, unsubscribe anytime.
    </p>

    <form id={`${uid}-form`} class="mt-5 flex flex-col gap-3">
      <div>
        <label for={`${uid}-email`} class="block text-sm font-medium mb-1.5">
          Email address
        </label>
        <input
          type="email"
          id={`${uid}-email`}
          name="email"
          required
          placeholder="you@example.com"
          class="w-full px-4 py-2.5 border border-base-content/15 rounded-xl bg-base-100/60 focus:ring-2 focus:ring-primary/50 focus:border-primary/40 text-base-content placeholder:text-base-content/40 transition-all"
        />
      </div>

      <div id={`${uid}-turnstile`} data-sitekey={siteKey}></div>

      <button
        type="submit"
        id={`${uid}-submit`}
        class="btn btn-primary w-full"
      >
        Subscribe
      </button>

      <div id={`${uid}-message`} class="text-sm hidden"></div>
    </form>

    <div class="mt-4 flex items-center gap-2">
      <input type="checkbox" id={`${uid}-dismiss`} class="checkbox checkbox-sm checkbox-primary" />
      <label for={`${uid}-dismiss`} class="text-base-content/60 cursor-pointer text-sm">Don't ask me again for 7 days</label>
    </div>

    <p class="mt-4 text-xs text-base-content/40">
      By subscribing, you agree to our
      <a href="/privacy" class="text-primary hover:underline">Privacy Policy</a>.
    </p>
  </div>
</div>
</>

<script define:vars={{ uid, apiBase: import.meta.env.PUBLIC_API_BASE ?? "", siteKey }}>
  const backdrop = document.getElementById(`${uid}-modal-backdrop`);
  const modal = document.getElementById(`${uid}-modal`);
  const closeBtn = document.getElementById(`${uid}-close`);
  const form = document.getElementById(`${uid}-form`);
  const submitBtn = document.getElementById(`${uid}-submit`);
  const message = document.getElementById(`${uid}-message`);
  const dismissCheckbox = document.getElementById(`${uid}-dismiss`);

  const isSubscribed = localStorage.getItem("newsletterSubscribed") === "true";
  const dismissUntil = localStorage.getItem("newsletterDismissUntil");
  const isDismissed = dismissUntil && Date.now() < parseInt(dismissUntil);

  let turnstileWidgetId = null;

  async function ensureTurnstile() {
    if (turnstileWidgetId !== null) {
      window.turnstile.reset(turnstileWidgetId);
      return;
    }

    if (!window.turnstile) {
      const script = document.createElement("script");
      script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
      script.async = true;
      document.head.appendChild(script);
      await new Promise((resolve) => {
        script.addEventListener("load", resolve);
      });
    }

    const container = document.getElementById(`${uid}-turnstile`);
    if (container) {
      turnstileWidgetId = window.turnstile.render(`#${uid}-turnstile`, {
        sitekey: siteKey,
      });
    }
  }

  function showModal() {
    backdrop.classList.remove("hidden");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        backdrop.classList.remove("opacity-0");
        modal.classList.remove("opacity-0");
      });
    });
    ensureTurnstile();
  }

  if (!isSubscribed && !isDismissed) {
    const scrollThreshold = 0.5;
    let hasShown = false;

    window.addEventListener("scroll", () => {
      if (hasShown) return;

      const scrollPercentage = window.scrollY / (document.body.scrollHeight - window.innerHeight);
      if (scrollPercentage >= scrollThreshold) {
        showModal();
        hasShown = true;
      }
    });
  }

  function closeModal() {
    backdrop.classList.add("opacity-0");
    modal.classList.add("opacity-0");
    setTimeout(() => {
      backdrop.classList.add("hidden");
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }, 300);

    if (dismissCheckbox.checked) {
      const sevenDays = 7 * 24 * 60 * 60 * 1000;
      localStorage.setItem("newsletterDismissUntil", String(Date.now() + sevenDays));
    }

    if (window.turnstile && turnstileWidgetId !== null) {
      window.turnstile.reset(turnstileWidgetId);
    }
  }

  closeBtn.addEventListener("click", closeModal);

  backdrop.addEventListener("click", closeModal);

  modal.addEventListener("click", (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) {
      closeModal();
    }
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const email = document.getElementById(`${uid}-email`)?.value;
    const turnstileInput = document.querySelector(
      `#${uid}-turnstile input[name='cf-turnstile-response']`,
    );
    const turnstileResponse = turnstileInput?.value;

    if (!turnstileResponse) {
      showMessage("Please complete the CAPTCHA", "error");
      return;
    }

    submitBtn.disabled = true;
    showMessage("Subscribing...", "info");

    try {
      const API_BASE = apiBase;
      const response = await fetch(`${API_BASE}/api/newsletter/subscribe`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email,
          token: turnstileResponse,
        }),
      });

      const data = await response.json();

      if (response.ok) {
        showMessage("Successfully subscribed! Check your email.", "success");
        form.reset();
        localStorage.setItem("newsletterSubscribed", "true");
        if (window.turnstile) {
          window.turnstile.reset(`#${uid}-turnstile`);
        }
        setTimeout(() => {
          closeModal();
        }, 2000);
      } else {
        showMessage(data.error || "Subscription failed", "error");
      }
    } catch (error) {
      showMessage("An error occurred. Please try again.", "error");
    } finally {
      submitBtn.disabled = false;
    }
  });

  function showMessage(text, type) {
    message.textContent = text;
    message.className = "text-sm";
    message.classList.remove("hidden");

    if (type === "success") {
      message.classList.add("text-success");
    } else if (type === "error") {
      message.classList.add("text-error");
    } else {
      message.classList.add("text-info");
    }
  }
</script>
