---
interface Props {
  href: string;
  imageUrl?: string;
  alt?: string;
  title?: string;
  description?: string;
}

const {
  href,
  imageUrl,
  alt = "Advertisement",
  title = "Sponsored",
  description,
} = Astro.props;

const isAdvertiseHere = !href;
const displayHref = isAdvertiseHere ? "/contact" : href;
const displayDescription = isAdvertiseHere ? "Advertise here" : (description || "");
const displayTitle = isAdvertiseHere ? "Advertisement" : (title || "Sponsored");
---

<a
  href={displayHref}
  target={isAdvertiseHere ? undefined : "_blank"}
  rel={isAdvertiseHere ? undefined : "noopener noreferrer sponsored"}
  class="group block w-full"
>
  <div class="border-base-300/80 bg-base-200/60 my-6 overflow-hidden rounded-lg border p-4 transition-[border-color,background-color] duration-200 hover:border-primary/40 hover:bg-base-200/80">
    <div class="flex items-center gap-3">
      {imageUrl && !isAdvertiseHere && (
        <img
          src={imageUrl}
          alt={alt}
          class="h-16 w-16 shrink-0 rounded-md object-cover"
          loading="lazy"
        />
      )}
      <div class="min-w-0 flex-1">
        <p class="text-base-content/42 font-mono text-[0.65rem] uppercase tracking-[0.18em]">
          {displayTitle}
        </p>
        {displayDescription && (
          <p class="text-base-content/78 mt-1 text-sm font-medium leading-snug">
            {displayDescription}
          </p>
        )}
      </div>
      {!isAdvertiseHere && (
        <div class="shrink-0">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="text-base-content/42 h-5 w-5 transition-colors duration-200 group-hover:text-primary"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
            />
          </svg>
        </div>
      )}
    </div>
  </div>
</a>
