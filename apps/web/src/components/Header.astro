---
import ButtonLink from "./ButtonLink.astro";

const links = [
  { to: "/", label: "Home" },
  { to: "/about", label: "About" },
  { to: "/tags", label: "Tags" },
];
---

<header>
  <div class="navbar bg-base-100 border-base-300 border-b">
    <div class="navbar-start">
      <ButtonLink href="/" class="text-xl font-bold">hmziq.rs</ButtonLink>
    </div>
    <div class="navbar-end gap-2">
      <nav class="flex gap-1">
        {links.map((link) => <ButtonLink href={link.to} size="sm">{link.label}</ButtonLink>)}
      </nav>
      <button
        type="button"
        class="btn btn-ghost btn-sm min-w-24"
        data-theme-toggle
        aria-label="Switch color theme"
      >
        Light mode
      </button>
    </div>
  </div>
</header>
