---
import type { ImageMetadata } from "astro";
import { siteConfig, routes, withBasePath } from "../config/site";
import CategoryBadge from "./CategoryBadge.astro";
import TagBadge from "./TagBadge.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
  category: string;
  cover?: ImageMetadata;
}

const { title, description, date, slug, tags, category, cover } = Astro.props as Props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const coverPath = cover ? withBasePath(siteConfig.basePath, cover.src) : undefined;
---

<article class="border-base-300 bg-base-200/55 hover:border-base-content/18 hover:bg-base-200 group rounded-[1.5rem] border p-4 transition-colors duration-200 sm:p-5">
  <div class="flex flex-col gap-4">
    {
      cover && coverPath && (
        <div class="-mx-4 -mt-4 sm:-mx-5 sm:-mt-5">
          <article class="border-base-300 bg-base-100 relative min-h-[22rem] overflow-hidden rounded-t-[1.4rem] border-b sm:min-h-[26rem] sm:rounded-t-[1.45rem]">
            <a href={routes.post(slug)} class="absolute inset-0" aria-label={`Read ${title}`}>
              <img
                src={coverPath}
                alt={title}
                width={cover.width}
                height={cover.height}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-200 group-hover:scale-[1.02]"
              />
            </a>
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-base-100 via-base-100/82 via-44% to-transparent transition-transform duration-300 ease-out will-change-transform group-hover:translate-y-10" />
            <div class="absolute inset-0 z-10 flex flex-col justify-end p-4 sm:p-5">
              <div class="text-base-content/56 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[0.7rem] tracking-[0.12em] uppercase">
                <time class="shrink-0">{formattedDate}</time>
                <span aria-hidden="true">/</span>
                <CategoryBadge category={category} class="shrink-0" />
              </div>
              <h2 class="mt-3 max-w-2xl text-[1.36rem] leading-tight font-semibold tracking-tight text-base-content sm:text-[1.58rem]">
                <a href={routes.post(slug)} class="group-hover:text-primary transition-colors">
                  {title}
                </a>
              </h2>
              <p class="text-base-content/76 mt-2.5 max-w-2xl text-sm leading-6 sm:text-[0.95rem]">
                {description}
              </p>
              <div class="mt-4 flex flex-wrap items-center gap-2">
                {tags.map((tag) => <TagBadge tag={tag} />)}
              </div>
            </div>
          </article>
        </div>
      )
    }
    {
      !coverPath && (
        <div class="min-w-0 px-0">
          <div class="text-base-content/42 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[0.7rem] tracking-[0.12em] uppercase">
            <time class="shrink-0">{formattedDate}</time>
            <span aria-hidden="true">/</span>
            <CategoryBadge category={category} class="shrink-0" />
          </div>
          <h2 class="mt-3 text-[1.32rem] leading-tight font-semibold tracking-tight sm:text-[1.5rem]">
            <a href={routes.post(slug)} class="group-hover:text-primary transition-colors">
              {title}
            </a>
          </h2>
          <p class="text-base-content/68 mt-2.5 max-w-2xl text-sm leading-6 sm:text-[0.95rem]">
            {description}
          </p>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            {tags.map((tag) => <TagBadge tag={tag} />)}
          </div>
        </div>
      )
    }
  </div>
</article>
