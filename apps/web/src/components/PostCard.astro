---
import CategoryBadge from "./CategoryBadge.astro";
import TagBadge from "./TagBadge.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
  category: string;
}

const { title, description, date, slug, tags, category } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="border-base-300 bg-base-200/55 hover:border-base-content/18 hover:bg-base-200 group rounded-[1.75rem] border p-5 transition-colors duration-200 sm:p-6">
  <div class="flex flex-col gap-4">
    <div class="flex items-start justify-between gap-2">
      <h2 class="text-xl leading-tight font-semibold tracking-tight sm:text-[1.45rem]">
        <a href={`/posts/${slug}`} class="group-hover:text-primary transition-colors">
          {title}
        </a>
      </h2>
      <CategoryBadge category={category} class="mt-0.5 shrink-0" />
    </div>
    <p class="text-base-content/68 max-w-2xl text-sm leading-6 sm:text-[0.95rem]">
      {description}
    </p>
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
      <time class="text-base-content/42 shrink-0 font-mono text-xs tracking-[0.08em] uppercase">
        {formattedDate}
      </time>
    </div>
  </div>
</article>
