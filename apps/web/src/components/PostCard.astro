---
import CategoryBadge from "./CategoryBadge.astro";
import TagBadge from "./TagBadge.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
  category: string;
}

const { title, description, date, slug, tags, category } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="card bg-base-200 border-base-300 border transition-colors">
  <div class="card-body gap-3">
    <div class="flex items-start justify-between gap-2">
      <h2 class="card-title text-xl">
        <a href={`/posts/${slug}`} class="hover:text-primary transition-colors">
          {title}
        </a>
      </h2>
      <CategoryBadge category={category} class="shrink-0" />
    </div>
    <p class="text-base-content/70 text-sm">{description}</p>
    <div class="flex flex-wrap items-center justify-between gap-2">
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
      <time class="text-base-content/40 shrink-0 text-xs">{formattedDate}</time>
    </div>
  </div>
</article>
