---
import { Icon } from "astro-icon/components";

interface Props {
  platform: string;
  class?: string;
}

const { platform, class: className } = Astro.props as Props;
const name = platform.toLowerCase();
const iconName =
  name === "email"
    ? "tabler:mail"
    : name === "telegram"
      ? "tabler:brand-telegram"
      : name === "x"
        ? "tabler:brand-x"
        : name === "github"
          ? "tabler:brand-github"
          : name === "linkedin"
            ? "tabler:brand-linkedin"
            : "tabler:link";
---

<Icon name={iconName} class:list={["h-5 w-5", className]} aria-hidden="true" />
