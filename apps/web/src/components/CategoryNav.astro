---
import ButtonLink from "./ButtonLink.astro";

interface Props {
  active?: string;
}

const { active } = Astro.props;

const categories = ["engineering", "tutorials", "opinions", "tools", "news"];
---

<nav class="flex flex-wrap gap-2">
  <ButtonLink
    href="/posts"
    size="sm"
    variant={!active ? "primary" : "ghost"}
    class="tracking-[0.12em] uppercase"
  >
    All
  </ButtonLink>
  {
    categories.map((cat) => (
      <ButtonLink
        href={`/category/${cat}`}
        size="sm"
        variant={active === cat ? "primary" : "ghost"}
        class="tracking-[0.12em] capitalize"
      >
        {cat}
      </ButtonLink>
    ))
  }
</nav>
