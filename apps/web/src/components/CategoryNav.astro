---
import { routes } from "../config/site";
import ButtonLink from "./ButtonLink.astro";

interface Props {
  categories: string[];
  active?: string;
}

const { categories, active } = Astro.props;
---

<nav class="flex flex-wrap gap-2">
  <ButtonLink
    href={routes.home}
    size="sm"
    variant={!active ? "primary" : "ghost"}
    class="tracking-[0.12em] uppercase"
  >
    All
  </ButtonLink>
  {
    categories.map((cat) => (
      <ButtonLink
        href={routes.category(cat)}
        size="sm"
        variant={active === cat ? "primary" : "ghost"}
        class="tracking-[0.12em] capitalize"
      >
        {cat}
      </ButtonLink>
    ))
  }
</nav>
