---
interface Props {
  uid?: string;
}

const { uid = "modal" } = Astro.props;
---

<div
  id={`${uid}-backdrop`}
  class="fixed inset-0 z-40 hidden opacity-0 bg-base-100/10 dark:bg-base-100/5 backdrop-blur-xs transition-opacity duration-300"
  aria-hidden="true"
></div>

<div
  id={uid}
  class="fixed inset-0 z-50 hidden items-center justify-center opacity-0 transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
>
  <slot />
</div>

<script define:vars={{ uid }}>
  let closeTimer;

  function getEls() {
    return {
      backdrop: document.getElementById(`${uid}-backdrop`),
      modal: document.getElementById(uid),
    };
  }

  function show() {
    clearTimeout(closeTimer);
    const { backdrop, modal } = getEls();
    if (!backdrop || !modal) return;
    backdrop.classList.remove("hidden");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        backdrop.classList.remove("opacity-0");
        modal.classList.remove("opacity-0");
      });
    });
  }

  function close() {
    const { modal } = getEls();
    if (!modal) return;
    const event = new CustomEvent(`${uid}:beforeclose`, { cancelable: true });
    modal.dispatchEvent(event);
    if (event.defaultPrevented) return;

    const { backdrop } = getEls();
    if (backdrop) backdrop.classList.add("opacity-0");
    modal.classList.add("opacity-0");
    closeTimer = setTimeout(() => {
      if (backdrop) backdrop.classList.add("hidden");
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }, 300);
  }

  function onKeydown(e) {
    if (e.key !== "Escape") return;
    const { modal } = getEls();
    if (!modal) return;
    if (!modal.classList.contains("hidden")) close();
  }

  document.addEventListener(`${uid}:show`, show);
  document.addEventListener(`${uid}:close`, close);

  document.addEventListener("keydown", onKeydown);

  document.addEventListener("click", (e) => {
    if (e.target.closest(`[data-modal-close]`)) close();
    if (e.target.id === `${uid}-backdrop`) close();
    if (e.target.id === uid) close();
  });
</script>
