---
import { siteConfig } from "../config/site";
import PageContainer from "./PageContainer.astro";

const year = new Date().getFullYear();
---

<footer class="border-base-300/80 mt-12 border-t">
  <PageContainer y="page">
    <div class="flex flex-col gap-3 text-sm">
      <nav class="flex flex-wrap items-center gap-x-4 gap-y-2">
        {siteConfig.footerNav.map((link) => (
          <a
            href={link.href}
            class="text-base-content/52 hover:text-primary font-mono text-[0.72rem] tracking-[0.14em] uppercase transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>
      <p class="text-base-content/48">
        © {year}{" "}
        <a
          href={siteConfig.siteUrl}
          class="hover:text-primary transition-colors duration-200"
        >
          {siteConfig.name}
        </a>
        . Built with{" "}
        <a
          href="https://astro.build"
          class="hover:text-primary transition-colors duration-200"
        >
          Astro
        </a>{" "}
        and deployed on{" "}
        <a
          href="https://pages.cloudflare.com"
          class="hover:text-primary transition-colors duration-200"
        >
          Cloudflare
        </a>
        .
      </p>
    </div>
  </PageContainer>
</footer>
