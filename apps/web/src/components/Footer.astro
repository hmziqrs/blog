---
import PageContainer from "./PageContainer.astro";

const year = new Date().getFullYear();
const links = [
  { href: "/tags", label: "Tags" },
  { href: "/categories", label: "Categories" },
  { href: "/contact", label: "Contact" },
  { href: "/privacy", label: "Privacy" },
  { href: "/terms", label: "Terms" },
];
---

<footer class="border-base-300/80 mt-12 border-t">
  <PageContainer y="tight">
    <div class="flex flex-col gap-3 text-sm">
      <p class="text-base-content/82 font-medium tracking-tight">hmziq.rs</p>
      <nav class="flex flex-wrap items-center gap-x-4 gap-y-2">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-base-content/52 hover:text-primary font-mono text-[0.72rem] tracking-[0.14em] uppercase transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>
      <p class="text-base-content/48">
        © {year} hmziq.rs. Writing about software engineering, tools, and systems.
      </p>
    </div>
  </PageContainer>
</footer>
