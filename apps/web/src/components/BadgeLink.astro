---
interface Props {
  href: string;
  variant?: "outline" | "ghost" | "accent";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const {
  href,
  variant = "outline",
  size = "md",
  class: className,
} = Astro.props;

const baseClass =
  "inline-flex items-center rounded-full border font-mono font-medium tracking-[0.01em] transition-colors duration-200";
const variantClass =
  variant === "ghost"
    ? "border-transparent bg-base-200 text-base-content/72 hover:bg-base-300 hover:text-base-content"
    : variant === "accent"
      ? "border-primary/18 bg-primary/12 text-primary hover:border-primary/28 hover:bg-primary/18"
      : "border-base-300 bg-base-100/80 text-base-content/72 hover:border-primary hover:text-primary";
const sizeClass =
  size === "sm"
    ? "px-2.5 py-1 text-[0.68rem]"
    : size === "lg"
      ? "px-3.5 py-2 text-xs"
      : "px-3 py-1.5 text-[0.72rem]";
---

<a href={href} class:list={[baseClass, variantClass, sizeClass, className]}>
  <slot />
</a>
