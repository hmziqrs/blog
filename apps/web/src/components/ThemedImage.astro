---
import type { ImageMetadata } from "astro";
import { siteConfig, withBasePath } from "../config/site";

interface Props {
  alt: string;
  dark: ImageMetadata;
  light?: ImageMetadata;
  loading?: "eager" | "lazy";
  class?: string;
}

const { alt, dark, light, loading = "lazy", class: className } = Astro.props as Props;

const darkSrc = withBasePath(siteConfig.basePath, dark.src);
const lightSrc = light ? withBasePath(siteConfig.basePath, light.src) : undefined;
---

<img
  src={darkSrc}
  alt={alt}
  width={dark.width}
  height={dark.height}
  loading={loading}
  class={className}
  data-theme-image
  data-dark-src={darkSrc}
  data-light-src={lightSrc}
/>
