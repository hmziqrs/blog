---
import type { ImageMetadata } from "astro";
import { siteConfig, withBasePath } from "../config/site";

interface Props {
  alt: string;
  image: ImageMetadata;
  loading?: "eager" | "lazy";
  class?: string;
}

const { alt, image, loading = "lazy", class: className } = Astro.props as Props;

const src = withBasePath(siteConfig.basePath, image.src);
---

<img
  src={src}
  alt={alt}
  width={image.width}
  height={image.height}
  loading={loading}
  class:list={[className, "theme-invert-light"]}
/>
