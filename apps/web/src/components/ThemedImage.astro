---
import type { CoverImage } from "../utils/cover-image";
import { siteConfig, withBasePath } from "../config/site";

interface Props {
  alt: string;
  image: CoverImage;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
}

const { alt, image, loading = "lazy", fetchpriority, class: className } = Astro.props as Props;

const src = image.src.startsWith("/") ? withBasePath(siteConfig.basePath, image.src) : image.src;
---

<img
  src={src}
  alt={alt}
  width={image.width}
  height={image.height}
  loading={loading}
  {fetchpriority}
  class:list={[className, "theme-invert-light"]}
/>
