---
interface Props {
  title: string;
  description?: string;
  class?: string;
  titleClass?: string;
  descriptionClass?: string;
}

const {
  title,
  description,
  class: className,
  titleClass = "mb-2 text-3xl font-bold",
  descriptionClass = "text-base-content/60",
} = Astro.props;
---

<header class:list={className}>
  <h1 class={titleClass}>{title}</h1>
  {description && <p class={descriptionClass}>{description}</p>}
  <slot />
</header>
