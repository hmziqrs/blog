---
interface Props {
  title: string;
  description?: string;
  class?: string;
  titleClass?: string;
  descriptionClass?: string;
}

const {
  title,
  description,
  class: className,
  titleClass = "mb-3 text-4xl font-semibold tracking-tight sm:text-5xl",
  descriptionClass = "max-w-2xl text-base leading-7 text-base-content/65 sm:text-[1.05rem]",
} = Astro.props;
---

<header class:list={className}>
  <h1 class={titleClass}>{title}</h1>
  {description && <p class={descriptionClass}>{description}</p>}
  <slot />
</header>
