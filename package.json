{
  "name": "blog",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@cloudflare/workers-types": "^4.20251213.0",
      "tailwindcss": "^4.1.18",
      "alchemy": "^0.82.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "deploy": "turbo -F @blog/infra deploy",
    "destroy": "turbo -F @blog/infra destroy",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "check": "oxlint && oxfmt --write",
    "test": "turbo -F web test",
    "test:coverage": "turbo -F web test -- --coverage",
    "qa": "bun run lint && bun run fmt:check && turbo -F web check && turbo -F web test"
  },
  "dependencies": {
    "@blog/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@blog/config": "workspace:*",
    "@cloudflare/workers-types": "catalog:",
    "@tailwindcss/typography": "^0.5.19",
    "daisyui": "^5.5.19",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.8"
}
