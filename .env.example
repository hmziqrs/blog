# ─── Cloudflare (shared — same for staging and prod) ────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Public (safe to expose in browser) ─────────────────────────────────────
# This .env is your LOCAL values only.
PUBLIC_API_BASE=            # empty = same-origin; set for cross-origin dev
PUBLIC_SITE_URL=            # set inline by deploy scripts — leave empty here
PUBLIC_TURNSTILE_SITE_KEY=  # staging: 1x00000000000000000000AA | prod: real key

# ─── Worker secrets (set via `wrangler secret put`, NOT here) ───────────────
# TURNSTILE_SECRET_KEY       staging: test key | prod: real secret
# NEWSLETTER_SEND_SECRET     different random hex per environment
# EMAIL_FROM_ADDRESS         same for both (e.g. no-reply@hmziq.rs)

# ─── For local newsletter sends via scripts/send-newsletter.ts ──────────────
SITE_URL=http://localhost:4321
NEWSLETTER_SEND_SECRET=

# ─── R2 / Media (differs per environment — use staging OR prod values) ──────
R2_ACCOUNT_ID=              # same as CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=           # staging: token scoped to blog-media-staging | prod: token scoped to blog-media
R2_SECRET_ACCESS_KEY=       # same — different token per bucket
R2_BUCKET_NAME=             # staging: blog-media-staging | prod: blog-media
R2_PUBLIC_URL=              # staging: r2.dev URL | prod: custom domain URL

# ─── Firebase Analytics (optional — skip if not using) ──────────────────────
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
