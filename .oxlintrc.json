{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/.wrangler/**", "**/public/web-components/**"],
  "rules": {
    "no-underscore-dangle": ["warn", { "allow": ["__dirname", "__initAnalytics"] }]
  }
}
