{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".astro/**"],
      "env": [
        "PUBLIC_API_BASE",
        "PUBLIC_SITE_URL",
        "PUBLIC_TURNSTILE_SITE_KEY",
        "PUBLIC_FIREBASE_API_KEY",
        "PUBLIC_FIREBASE_AUTH_DOMAIN",
        "PUBLIC_FIREBASE_PROJECT_ID",
        "PUBLIC_FIREBASE_STORAGE_BUCKET",
        "PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "PUBLIC_FIREBASE_APP_ID",
        "PUBLIC_FIREBASE_MEASUREMENT_ID",
        "CONTENT_DIR",
        "R2_PUBLIC_URL",
        "SITE_URL"
      ]
    },
    "build:staging": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".astro/**"],
      "env": [
        "PUBLIC_API_BASE",
        "PUBLIC_SITE_URL",
        "PUBLIC_TURNSTILE_SITE_KEY",
        "PUBLIC_FIREBASE_API_KEY",
        "PUBLIC_FIREBASE_AUTH_DOMAIN",
        "PUBLIC_FIREBASE_PROJECT_ID",
        "PUBLIC_FIREBASE_STORAGE_BUCKET",
        "PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "PUBLIC_FIREBASE_APP_ID",
        "PUBLIC_FIREBASE_MEASUREMENT_ID",
        "CONTENT_DIR",
        "R2_PUBLIC_URL",
        "SITE_URL"
      ]
    },
    "build:prod": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".astro/**"],
      "env": [
        "PUBLIC_API_BASE",
        "PUBLIC_SITE_URL",
        "PUBLIC_TURNSTILE_SITE_KEY",
        "PUBLIC_FIREBASE_API_KEY",
        "PUBLIC_FIREBASE_AUTH_DOMAIN",
        "PUBLIC_FIREBASE_PROJECT_ID",
        "PUBLIC_FIREBASE_STORAGE_BUCKET",
        "PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "PUBLIC_FIREBASE_APP_ID",
        "PUBLIC_FIREBASE_MEASUREMENT_ID",
        "CONTENT_DIR",
        "R2_PUBLIC_URL",
        "SITE_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "deploy": {
      "cache": false
    },
    "destroy": {
      "cache": false
    }
  }
}
